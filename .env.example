APP_ENV=production
API_BASE_URL=https://api.skinouva.shop
FRONTEND_BASE_URL=https://skinouva.shop
DATABASE_URL=postgresql://postgres:<password>@skinouva_skinouva-db:5432/Skinouva?sslmode=disable
CORS_ORIGINS=https://skinouva.shop,https://www.skinouva.shop

# Google Sheet — runs on server 24/7 (PC off = no effect).
# Apps Script: Script property SKINOUVA_WEBHOOK_SECRET must match SHEETS_WEBHOOK_SECRET below.
# Do not redeploy Apps Script without keeping the same secret + updating SHEETS_WEBHOOK_URL if URL changes.
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
SHEETS_WEBHOOK_SECRET=skinouva-sheet-2026

META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_TEST_EVENT_CODE=

SNAP_PIXEL_ID=
SNAP_ACCESS_TOKEN=

MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

COD_NETWORK_API_URL=https://api.cod.network/api/v2
COD_NETWORK_API_TOKEN=
COD_NETWORK_WEBHOOK_SECRET=
COD_NETWORK_DEFAULT_REFERRAL_ID=
COD_NETWORK_REFERRAL_TRANEXAMIC=
COD_NETWORK_REFERRAL_AZELAIC=
COD_NETWORK_DEFAULT_COUNTRY=AE
COD_NETWORK_DEFAULT_CITY=
COD_NETWORK_PENDING_ADDRESS=UAE - address to be confirmed by phone

ORDER_WEBHOOK_TIMEOUT_SECONDS=8
LOG_LEVEL=info

# Admin dashboard (required for /admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_SESSION_TTL_SECONDS=604800
